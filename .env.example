# Copy to .env (chmod 600) and fill in.
# .env is .gitignore'd; never commit it.

# Required for news headlines, hot-take synthesis, and grants polling.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Override the default Claude model used for LLM-backed sources.
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional. Override the path to the Thunderbird MCP bridge if you cloned it elsewhere.
# THUNDERBIRD_MCP_BRIDGE=/home/travis-turner/projects/thunderbird-mcp/mcp-bridge.cjs

# Optional. Cap LLM calls per source per day to control spend.
# LLM_DAILY_CALL_CAP_NEWS=120
# LLM_DAILY_CALL_CAP_GRANTS=8
